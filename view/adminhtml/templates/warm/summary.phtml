<script type="text/javascript">
    require(['jquery', 'https://www.gstatic.com/charts/loader.js'], function($) {
        google.charts.load('current', {'packages':['corechart']});
        
        var chartData = {
            'today': <?= json_encode($block->getChartData('today')) ?>,
            '24h': <?= json_encode($block->getChartData('24h')) ?>,
            '7days': <?= json_encode($block->getChartData('7days')) ?>
        };

        function drawChart(period) {
            var dataArray = [['Time', 'Pending', 'Done', 'Error']];
            var periodData = chartData[period];
            
            if (!periodData || periodData.length === 0) {
                $('#bydn-warm-chart').html('<div class="bydn-warm-chart-placeholder">' + <?= json_encode(__('No data available for this period.')) ?> + '</div>');
                return;
            }

            periodData.forEach(function(row) {
                dataArray.push([
                    row.date,
                    row.pending,
                    row.done,
                    row.error
                ]);
            });

            var data = google.visualization.arrayToDataTable(dataArray);

            var options = {
                curveType: 'function',
                legend: { position: 'bottom' },
                chartArea: { width: '90%', height: '75%', top: 20 },
                colors: ['#1979c3', '#185a31', '#b4002d'],
                vAxis: {
                    viewWindow: { min: 0 }
                },
                hAxis: {
                    showTextEvery: Math.ceil(periodData.length / 12) || 1
                },
                height: 350,
                backgroundColor: 'transparent'
            };

            var chart = new google.visualization.LineChart(document.getElementById('bydn-warm-chart'));
            chart.draw(data, options);
        }

        google.charts.setOnLoadCallback(function() {
            drawChart('today');
        });

        $(document).on('click', '.bydn-warm-period-btn', function() {
            var period = $(this).data('period');
            $('.bydn-warm-period-btn').removeClass('active');
            $(this).addClass('active');
            drawChart(period);
        });

        $(window).on('resize', function() {
            var activePeriod = $('.bydn-warm-period-btn.active').data('period');
            if (activePeriod) {
                drawChart(activePeriod);
            }
        });
    });
</script>

