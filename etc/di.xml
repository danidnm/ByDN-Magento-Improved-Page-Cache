<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- Same page cache for logged in and guest -->
    <type name="Magento\Framework\App\Http\Context">
        <plugin name="bydn-improved-page-cache-x-vary-fix" type="Bydn\ImprovedPageCache\Plugin\Magento\Framework\App\Http\Context"/>
    </type>
    <!--  Warm Varnish page after purge -->
    <type name="\Magento\CacheInvalidate\Model\PurgeCache">
        <plugin name="bydn-improved-page-cache-invalidate-cache-to-warm" type="Bydn\ImprovedPageCache\Plugin\Magento\CacheInvalidate\Model\PurgeCache"/>
    </type>

    <!-- Commands -->
    <type name="Magento\Framework\Console\CommandList">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="bydnCacheEnqueue" xsi:type="object">Bydn\ImprovedPageCache\Console\Enqueue</item>
                <item name="bydnCacheWarm" xsi:type="object">Bydn\ImprovedPageCache\Console\Warm</item>
            </argument>
        </arguments>
    </type>

    <!-- WarmItem grid listing data provider -->
    <type name="Magento\Framework\View\Element\UiComponent\DataProvider\CollectionFactory">
        <arguments>
            <argument name="collections" xsi:type="array">
                <item name="cache_warm_item_grid_data_source" xsi:type="string">WarmItemGridCollection</item>
            </argument>
        </arguments>
    </type>
    <virtualType name="WarmItemGridCollection" type="Magento\Framework\View\Element\UiComponent\DataProvider\SearchResult">
        <arguments>
            <argument name="mainTable" xsi:type="string">bydn_warm_item</argument>
            <argument name="resourceModel" xsi:type="string">Bydn\ImprovedPageCache\Model\ResourceModel\WarmItem\Collection</argument>
        </arguments>
    </virtualType>

    <!-- Custom Logger -->
    <virtualType name="BydnImprovedPageCacheLoggerHandler" type="Magento\Framework\Logger\Handler\Base">
        <arguments>
            <argument name="fileName" xsi:type="string">var/log/bydn_cache.log</argument>
        </arguments>
    </virtualType>
    <virtualType name="BydnImprovedPageCacheLogger" type="Magento\Framework\Logger\Monolog">
        <arguments>
            <argument name="name" xsi:type="string">bydnImprovedPageCache</argument>
            <argument name="handlers" xsi:type="array">
                <item name="debug" xsi:type="object">BydnImprovedPageCacheLoggerHandler</item>
            </argument>
        </arguments>
    </virtualType>

    <type name="Bydn\ImprovedPageCache\Console\Enqueue">
        <arguments>
            <argument name="logger" xsi:type="object">BydnImprovedPageCacheLogger</argument>
        </arguments>
    </type>
    <type name="Bydn\ImprovedPageCache\Console\Warm">
        <arguments>
            <argument name="logger" xsi:type="object">BydnImprovedPageCacheLogger</argument>
        </arguments>
    </type>
    <type name="Bydn\ImprovedPageCache\Model\Queue\Publisher">
        <arguments>
            <argument name="logger" xsi:type="object">BydnImprovedPageCacheLogger</argument>
        </arguments>
    </type>
    <type name="Bydn\ImprovedPageCache\Model\Queue\Consumer">
        <arguments>
            <argument name="logger" xsi:type="object">BydnImprovedPageCacheLogger</argument>
        </arguments>
    </type>
    <type name="Bydn\ImprovedPageCache\Model\WarmItemRepository">
        <arguments>
            <argument name="logger" xsi:type="object">BydnImprovedPageCacheLogger</argument>
        </arguments>
    </type>
    <type name="Bydn\ImprovedPageCache\Plugin\Amasty\Shopby\Helper\UrlBuilder">
        <arguments>
            <argument name="logger" xsi:type="object">BydnImprovedPageCacheLogger</argument>
        </arguments>
    </type>
    <type name="Bydn\ImprovedPageCache\Observer\WidgetsCache">
        <arguments>
            <argument name="logger" xsi:type="object">BydnImprovedPageCacheLogger</argument>
        </arguments>
    </type>
    <type name="Bydn\ImprovedPageCache\Plugin\Magento\CacheInvalidate\Model\PurgeCache">
        <arguments>
            <argument name="logger" xsi:type="object">BydnImprovedPageCacheLogger</argument>
        </arguments>
    </type>

</config>
